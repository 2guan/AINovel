# =========================================================================
# AI Novel Writing Assistant - Docker Compose 部署环境变量模板
# =========================================================================
# 使用方法:
# 1. 复制本文件并重命名为 `.env` (在 docker-compose.yml 所在根目录下)
# 2. 修改对应的大模型 API 密钥以及部署服务器 IP/域名
# 3. 执行 `docker compose up -d` 启动全部服务
# =========================================================================

# -------------------------------------------------------------------------
# 1. 数据库配置 (PostgreSQL)
# -------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password_123
POSTGRES_DB=ai_novel

# -------------------------------------------------------------------------
# 2. 前端请求后端的 API 基准地址
# -------------------------------------------------------------------------
# 采用 0.4.0 全新 Nginx 相对路径同源网关，默认直接使用相对路径 /api，免去手动配置主机 IP 和端口跨域。
VITE_API_BASE_URL=/api
CORS_ORIGIN=http://localhost:4002

# -------------------------------------------------------------------------
# 3. 大语言模型 API 密钥 (按需配置)
# -------------------------------------------------------------------------
# OpenAI 配置
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek 配置 (强烈推荐，续写/智能查重重写等默认调用)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 硅基流动 (SiliconFlow) 配置
SILICONFLOW_API_KEY=

# Anthropic 配置
ANTHROPIC_API_KEY=

# Google Gemini 配置
GEMINI_API_KEY=

# Moonshot (Kimi) 配置
KIMI_API_KEY=

# 智谱清言 (GLM) 配置
GLM_API_KEY=

# 阿里通义千问 (Qwen) 配置
QWEN_API_KEY=

# -------------------------------------------------------------------------
# 4. 向量库与检索配置 (RAG)
# -------------------------------------------------------------------------
RAG_ENABLED=true
# 嵌入模型供应商，可选: openai, siliconflow 等 (保持与您填写的 API_KEY 一致)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
